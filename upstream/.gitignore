# Process Triage - .gitignore

# Logs
*.log

# Test artifacts
.bats-run-*

# Editor/IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store

# Temporary files
*.tmp

# UBS scan output
ubs_output.txt

# bv (beads viewer) local config and caches
.bv/

# Rust build artifacts
target/

# NTM agent coordination
.ntm/

# Compiled binaries
a.out
/pt-core

# NTM agent coordination
.ntm/
._*
*.png

# Dependency upgrade progress (in-progress work)
UPGRADE_LOG.md
claude-upgrade-progress.json

# Profiling and benchmark data
perf.data
perf.data.*
perf_*.data
perf_*.data.*
flamegraph*.svg

# Local scratch DBs
storage.sqlite3
storage.sqlite3-*

# Agent coordination config
.agent-mail.yaml

# Beads history snapshots
.beads/.br_history/

# Root-level policy files (generated by config validation)
policy.*.json

# ACFS ephemeral patterns (auto-generated agent artifacts)
core.*
cline.mcp.json
codex.mcp.json
cursor.mcp.json
gemini.mcp.json
opencode.json
windsurf.mcp.json
*.mcp.json.*.bak
.opencode.json.*.bak
.windsurf.mcp.json.*.bak
.agent-mail-project-id
*.sqlite3.bak
*.sqlite3.corrupt*
storage.sqlite3.corrupt-*
storage.sqlite3-shm.corrupt-*
storage.sqlite3-wal.corrupt-*
.beads/*.corrupt*
.beads/*.pre_repair_*
.beads/*.repair_candidate_*
.beads/*.bak-corrupt
.beads/recovery_*/
target-*/
crates/*/target*/
